NODE_ENV=test
PORT=0

# Database — reuse existing postgres16 container, separate DB
DATABASE_URL=postgresql://postgres@localhost:5432/roundu_test

# Redis — reuse existing container
REDIS_URL=redis://localhost:6379

# JWT secrets MUST be >=32 chars each (enforced by env.ts)
JWT_ACCESS_SECRET=test-access-secret-do-not-use-in-prod-123456
JWT_REFRESH_SECRET=test-refresh-secret-do-not-use-in-prod-123456
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# AWS S3 (dummy values for tests)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_S3_BUCKET=roundu-test

# Stripe (dummy test-mode values; Stripe flows are skipped)
STRIPE_SECRET_KEY=sk_test_dummy
STRIPE_WEBHOOK_SECRET=whsec_test_dummy

# MSG91 OTP (dummy)
MSG91_AUTH_KEY=test
MSG91_TEMPLATE_ID=test
MSG91_SENDER_ID=ROUNDU

# Firebase FCM (dummy)
FIREBASE_PROJECT_ID=test
FIREBASE_CLIENT_EMAIL=test@example.com
FIREBASE_PRIVATE_KEY=test-key

# ElevenLabs (dummy)
ELEVENLABS_API_KEY=test
ELEVENLABS_AGENT_ID=test

# vLLM (dummy)
VLLM_BASE_URL=http://localhost:8000
VLLM_MODEL=test-model

# Google Maps (dummy)
GOOGLE_MAPS_API_KEY=test

# DigiLocker (dummy)
DIGILOCKER_CLIENT_ID=test
DIGILOCKER_CLIENT_SECRET=test
DIGILOCKER_REDIRECT_URI=http://localhost:3000/kyc/callback
DIGILOCKER_WEBHOOK_SECRET=test

# App
APP_URL=http://localhost:3000
APP_BASE_URL=https://roundu.test
CORS_ORIGINS=http://localhost:3000
